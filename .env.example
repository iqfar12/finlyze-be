# ── Server ──────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── CORS (comma-separated origins) ─────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# ── AI Provider API Keys (set whichever you use) ───────────────
ANTHROPIC_API_KEY=sk-ant-api03-xxxx
GROQ_API_KEY=gsk_xxxx
GEMINI_API_KEY=AIzaSy-xxxx

# ── Default AI provider: "groq" | "claude" | "gemini" ─────────
DEFAULT_PROVIDER=groq

# ── Rate Limiting ──────────────────────────────────────────────
# Analysis endpoint: max requests per window
RATE_LIMIT_ANALYZE_MAX=10
RATE_LIMIT_ANALYZE_WINDOW_MS=3600000

# Chat endpoint: max requests per window
RATE_LIMIT_CHAT_MAX=30
RATE_LIMIT_CHAT_WINDOW_MS=3600000

# Global per-IP: max requests per window
RATE_LIMIT_GLOBAL_MAX=100
RATE_LIMIT_GLOBAL_WINDOW_MS=3600000

# ── API Key for frontend→backend auth (optional) ──────────────
API_SECRET_KEY=your-secret-key-here
